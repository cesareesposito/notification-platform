{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },

  "ConnectionStrings": {
    "NotificationDb": "Host=localhost;Port=5432;Database=notifications;Username=notification;Password=secret"
  },

  "RabbitMq": {
    "Host": "rabbitmq",
    "Port": 5672,
    "VirtualHost": "/",
    "Username": "guest",
    "Password": "guest",
    "QueueName": "notifications",
    "ExchangeName": "notification.exchange",
    "RoutingKey": "notification.send",
    "MaxRetries": 3,
    "RetryDelaySeconds": 10
  },

  "DataProtection": {
    "KeysPath": "/keys"
  },

  "Providers": {
    "Smtp": {
      "Host": "localhost",
      "Port": 587,
      "Username": "",
      "Password": "",
      "UseSsl": false,
      "SkipCertificateValidation": false,
      "DefaultFromEmail": "noreply@example.com",
      "DefaultFromName": "Notification Platform"
    },
    "Firebase": {
      "CredentialFile": "/credentials/firebase-default.json",
      "ProjectId": ""
    }
  },

  "Templates": {
    "FileSystem": {
      "BasePath": "templates"
    }
  }
}
